      "source": [
        "from contextlib import nullcontext\n",
        "array = [\"水\",\"金\",\"地\",\"火\",\"木\",\"土\",\"天\",\"海\",\"冥\"]\n",
        "\n",
        "#forループで水～冥の9行を表示\n",
        "for planet in array:\n",
        "    print(planet)\n",
        "\n",
        "#whileループで水～冥の9行を表示\n",
        "\n",
        "i = 0\n",
        "\n",
        "while i < 9:\n",
        "\n",
        "  num = array[i]\n",
        "  i = i + 1\n",
        "  print(num)\n",
        "\n",
        "\n"
